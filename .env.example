# ============================================================================
# DeepTutor — environment configuration
# ============================================================================
# Copy to .env and fill in the keys you need. `.env` is gitignored.
#
# Every API key is ENVIRONMENT-ONLY: read exclusively from the environment for security
#
# One key covers a provider across every service it backs — e.g. OPENAI_API_KEY
# handles OpenAI LLM + embeddings + TTS/STT + image generation.
#
# NOTE: never put a comment on the same line as `KEY=value`. Docker's
# `--env-file` parser folds trailing text into the value.
# ============================================================================

# ============================================================================
# REQUIRED — set at least ONE LLM provider key
# ============================================================================
# A minimal run needs a single LLM key. OpenAI also covers embeddings, TTS/STT,
# and image generation. Use whichever provider you have.
OPENAI_API_KEY=

# ============================================================================
# OPTIONAL
# ============================================================================

# --- Additional LLM providers ---
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
MOONSHOT_API_KEY=
DASHSCOPE_API_KEY=
MINIMAX_API_KEY=
ZAI_API_KEY=
ZHIPUAI_API_KEY=
STEPFUN_API_KEY=
XIAOMIMIMO_API_KEY=
NVIDIA_NIM_API_KEY=
QIANFAN_API_KEY=
OPENROUTER_API_KEY=
AZURE_OPENAI_API_KEY=

# --- Embedding / rerank (non-LLM) ---
COHERE_API_KEY=
JINA_API_KEY=

# --- Web search ---
TAVILY_API_KEY=
BRAVE_API_KEY=
EXA_API_KEY=
SERPER_API_KEY=
PERPLEXITY_API_KEY=

# --- Document parsing / RAG services ---
MINERU_API_TOKEN=
PAGEINDEX_API_KEY=
LIGHTRAG_API_KEY=

# --- Auth / PocketBase (also needs a one-time on-disk JSON edit to enable) ---
AUTH_PASSWORD_HASH=
POCKETBASE_ADMIN_PASSWORD=

# --- Demo mode (per-IP rate limits; OFF by default) ---
# Set DEMO=true only on a PUBLIC demo where visitors chat against your key,
# to cap per-visitor spend. Limit overrides are optional. See README "Demo mode".
DEMO=false
DEMO_RATE_LIMIT_PER_MIN=15
DEMO_RATE_LIMIT_PER_HOUR=200

# --- Local Docker/compose only (ignored on Render) ---
# Host-side loopback bindings and timezone. Override if 8001/3782/8090 are taken.
HOST_PORT_BACKEND=8001
HOST_PORT_FRONTEND=3782
HOST_PORT_POCKETBASE=8090
TZ=UTC
